# Slack Bot Token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Slack App Token for Socket Mode (xapp-...)
SLACK_APP_TOKEN=xapp-your-app-token

# Slack Signing Secret
SLACK_SIGNING_SECRET=your-signing-secret

# Giphy API Key
GIPHY_API_KEY=your-giphy-api-key

# PostgreSQL Database URL
DATABASE_URL=postgresql://user:password@host:5432/database

# Reaction emoji names to track (comma-separated, without colons)
# REACTION_NAMES=helpful,thank-you,brilliant,clutch

# Channel for leaderboard posts (name or ID)
# LEADERBOARD_CHANNEL=dynamic-agency-hq

# Channel for milestone shoutouts (defaults to LEADERBOARD_CHANNEL)
# SHOUTOUT_CHANNEL=dynamic-agency-hq
